---
import AppShell from "../components/AppShell.astro";
import { listDiseases, totalSamples } from "../data/diseases";

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const diseases = listDiseases();

// Categorías únicas para los chips de filtro rápido.
const categorias = ["Todas", ...Array.from(new Set(diseases.map((d) => d.categoria)))];
---

<AppShell
  active="buscador"
  role="Hospital"
  crumbs={[{ label: "Inicio", href: base }, { label: "Buscador" }]}
  title="Buscador · BioRare"
>
  <div class="page-head">
    <div>
      <h1>Buscador de enfermedades</h1>
      <p>Localiza una enfermedad por nombre, código ORPHA / ICD-10 o cromosoma y abre su ficha.</p>
    </div>
    <span class="count-pill" aria-live="polite"><b id="result-count">{diseases.length}</b> de {diseases.length}</span>
  </div>

  <!-- ===== Barra de búsqueda y filtros ===== -->
  <div class="search-bar card">
    <label class="bigsearch">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4-4"/></svg>
      <input
        type="search"
        id="disease-search"
        placeholder="Buscar: Rett, ORPHA:778, F84.2, cromosoma X…"
        autocomplete="off"
      />
    </label>
    <div class="catfilters" role="group" aria-label="Filtrar por categoría">
      {
        categorias.map((c, i) => (
          <button class={`filter ${i === 0 ? "is-active" : ""}`} data-cat={c}>{c}</button>
        ))
      }
    </div>
  </div>

  <!-- ===== Resultados ===== -->
  <ul class="results" id="results">
    {
      diseases.map((d) => (
        <li
          class="result"
          data-name={`${d.nombre} ${d.orpha} ${d.icd10} ${d.cromosoma} ${d.gene.gen} ${d.categoria}`.toLowerCase()}
          data-cat={d.categoria}
        >
          <a class="result__card card" href={`${base}ficha/${d.slug}`}>
            <div class="result__head">
              <span class="chip chip-teal">{d.categoria}</span>
              <span class="result__samples">{totalSamples(d)} muestras en red</span>
            </div>
            <h2>{d.nombre}</h2>
            <div class="result__codes">
              <span class="mono"><b>ORPHA</b> {d.orpha}</span>
              <span class="mono"><b>ICD-10</b> {d.icd10}</span>
              <span class="mono"><b>Cr.</b> {d.cromosoma}</span>
            </div>
            <p class="result__summary">{d.resumen}</p>
            <span class="result__cta">
              Abrir ficha
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        </li>
      ))
    }
  </ul>

  <p class="results-empty" id="results-empty" hidden>
    No hay enfermedades que coincidan con tu búsqueda.
  </p>
</AppShell>

<style>
  .page-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 22px;
    flex-wrap: wrap;
  }
  .page-head h1 {
    font-size: 1.7rem;
  }
  .page-head p {
    color: var(--muted);
    margin-top: 4px;
  }
  .count-pill {
    font-size: 0.85rem;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 7px 14px;
    white-space: nowrap;
  }
  .count-pill b {
    color: var(--coral-dark);
  }

  /* Barra de búsqueda */
  .search-bar {
    padding: 18px 20px;
    margin-bottom: 22px;
  }
  .bigsearch {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 16px;
  }
  .bigsearch input {
    border: none;
    outline: none;
    background: none;
    font-family: inherit;
    font-size: 1.05rem;
    color: var(--ink);
    width: 100%;
  }
  .catfilters {
    display: flex;
    gap: 7px;
    flex-wrap: wrap;
    margin-top: 16px;
  }
  .filter {
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--ink-soft);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 7px 14px;
    transition: all 0.15s ease;
  }
  .filter:hover {
    border-color: var(--coral);
  }
  .filter.is-active {
    background: var(--coral);
    color: #fff;
    border-color: var(--coral);
  }

  /* Resultados */
  .results {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 18px;
  }
  .result__card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 20px 22px;
    transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
  }
  .result__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--coral);
  }
  .result__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 12px;
  }
  .result__samples {
    font-size: 0.78rem;
    color: var(--muted);
  }
  .result__card h2 {
    font-size: 1.2rem;
    margin-bottom: 10px;
  }
  .result__codes {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
    margin-bottom: 12px;
  }
  .result__codes span {
    font-size: 0.78rem;
    color: var(--ink-soft);
  }
  .result__codes b {
    color: var(--muted);
    font-weight: 600;
    margin-right: 3px;
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.03em;
  }
  .result__summary {
    font-size: 0.9rem;
    color: var(--ink-soft);
    flex: 1;
  }
  .result__cta {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-top: 16px;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--coral-dark);
  }
  .mono {
    font-family: var(--font-mono);
  }
  .results-empty {
    padding: 48px;
    text-align: center;
    color: var(--muted);
  }

  @media (max-width: 560px) {
    .results {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const search = document.querySelector<HTMLInputElement>("#disease-search");
  const filters = Array.from(document.querySelectorAll<HTMLButtonElement>(".filter"));
  const items = Array.from(document.querySelectorAll<HTMLLIElement>(".result"));
  const empty = document.querySelector<HTMLElement>("#results-empty");
  const counter = document.querySelector<HTMLElement>("#result-count");
  let activeCat = "Todas";

  function apply() {
    const q = (search?.value ?? "").trim().toLowerCase();
    let shown = 0;
    items.forEach((el) => {
      const catOk = activeCat === "Todas" || el.dataset.cat === activeCat;
      const qOk = !q || (el.dataset.name ?? "").includes(q);
      const visible = catOk && qOk;
      el.style.display = visible ? "" : "none";
      if (visible) shown++;
    });
    if (empty) empty.hidden = shown !== 0;
    if (counter) counter.textContent = String(shown);
  }

  filters.forEach((f) =>
    f.addEventListener("click", () => {
      filters.forEach((x) => x.classList.remove("is-active"));
      f.classList.add("is-active");
      activeCat = f.dataset.cat ?? "Todas";
      apply();
    })
  );
  search?.addEventListener("input", apply);

  // Prefiltrar desde ?q= (lo usa la búsqueda del topbar).
  const params = new URLSearchParams(window.location.search);
  const initial = params.get("q");
  if (initial && search) {
    search.value = initial;
    apply();
  }
  search?.focus();
</script>
