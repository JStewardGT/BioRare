---
import AppShell from "../../components/AppShell.astro";
import { listDiseases, supplyCategories, stockMeta } from "../../data/diseases";
import type { Disease } from "../../data/diseases";

// Una página estática por enfermedad: /ficha/<slug>
export function getStaticPaths() {
  return listDiseases().map((d) => ({
    params: { slug: d.slug },
    props: { disease: d },
  }));
}

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");

const tabs = [
  { id: "resumen", label: "Resumen genético-clínico" },
  { id: "diagnostico", label: "Diagnóstico" },
  { id: "sourcing", label: "Sourcing" },
  { id: "muestras", label: "Muestras en la red" },
  { id: "literatura", label: "Literatura" },
];

const { disease } = Astro.props as { disease: Disease };

// Atajos hacia los bloques de datos que consume la plantilla.
const { clinical, treatments, variants, gene, diagnosis } = disease;
const supplies = disease.sourcing;
const networkSamples = disease.samples;
const papers = disease.papers;
---

<AppShell
  active="buscador"
  role="Hospital"
  crumbs={[{ label: "Inicio", href: base }, { label: "Buscador", href: base + "buscador" }, { label: disease.nombre }]}
  title={`${disease.nombre} · Ficha · BioRare`}
>
  <!-- ===== Cabecera de la enfermedad ===== -->
  <header class="disease-head card">
    <div class="disease-head__main">
      <span class="eyebrow">
        <span class="dot" style="background: var(--coral)"></span> Ficha de enfermedad
      </span>
      <h1>{disease.nombre}</h1>
      <div class="disease-meta">
        <span class="meta-pill"><b>ORPHA</b> {disease.orpha}</span>
        <span class="meta-pill"><b>ICD-10</b> {disease.icd10}</span>
        <span class="meta-pill"><b>Cromosoma</b> {disease.cromosoma}</span>
        <span class="meta-pill"><b>Prevalencia</b> {disease.prevalencia}</span>
      </div>
    </div>
    <div class="disease-head__actions">
      <span class="chip chip-teal">{disease.categoria}</span>
      <button class="btn btn-ghost btn-sm" onclick="window.print()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2M6 14h12v8H6z"/></svg>
        Exportar PDF
      </button>
    </div>
  </header>

  <!-- ===== Pestañas ===== -->
  <div class="tabs" role="tablist" aria-label="Secciones de la ficha">
    {
      tabs.map((t, i) => (
        <button
          class={`tab ${i === 0 ? "is-active" : ""}`}
          role="tab"
          id={`tab-${t.id}`}
          aria-controls={`panel-${t.id}`}
          aria-selected={i === 0 ? "true" : "false"}
          data-tab={t.id}
        >
          {t.label}
        </button>
      ))
    }
  </div>

  <!-- ============ PANEL: RESUMEN ============ -->
  <section class="tabpanel is-active" id="panel-resumen" role="tabpanel" aria-labelledby="tab-resumen">
    <div class="resumen">
      <!-- Columna ancha: clínico -->
      <div class="col-clinic">
        <article class="card block">
          <div class="block__head">
            <h2>Aspectos clínicos críticos</h2>
            <div class="legend">
              <span><span class="dot" style="background:var(--red)"></span> Severidad alta</span>
              <span><span class="dot" style="background:var(--amber-state)"></span> Severidad media</span>
            </div>
          </div>
          <ul class="clinic-list">
            {
              clinical.map((c) => (
                <li class={`clinic-item clinic-item--${c.sev}`}>
                  <span class={`chip ${c.sev === "alta" ? "chip-red" : "chip-amber"}`}>
                    {c.sev === "alta" ? "Alta" : "Media"}
                  </span>
                  <div>
                    <strong>{c.label}</strong>
                    <p>{c.desc}</p>
                  </div>
                </li>
              ))
            }
          </ul>
        </article>

        <article class="card block">
          <div class="block__head">
            <h2>Tratamientos experimentales</h2>
            <span class="panel__sub">Estado y fase clínica</span>
          </div>
          <div class="treat-grid">
            {
              treatments.map((t) => (
                <div class="treat">
                  <div class="treat__top">
                    <strong>{t.name}</strong>
                    <span class={`chip ${t.status === "approved" ? "chip-green" : "chip-teal"}`}>
                      {t.phase}
                    </span>
                  </div>
                  <p>{t.note}</p>
                </div>
              ))
            }
          </div>
        </article>
      </div>

      <!-- Columna angosta: genético -->
      <aside class="col-gene">
        <article class="card block block--dark">
          <h2 class="gene-title">Datos genéticos</h2>
          <dl class="gene-facts">
            <div><dt>Gen</dt><dd>{gene.gen}</dd></div>
            <div><dt>Cromosoma</dt><dd>{gene.cromosoma}</dd></div>
            <div><dt>Locus</dt><dd>{gene.locus}</dd></div>
            <div><dt>Herencia</dt><dd>{gene.herencia}</dd></div>
            <div><dt>OMIM</dt><dd>{gene.omim}</dd></div>
          </dl>
        </article>

        <article class="card block">
          <div class="block__head">
            <h2>Variantes patogénicas</h2>
          </div>
          <div class="var-table">
            <div class="var-row var-row--head">
              <span>HGVS</span><span>Proteína</span><span>Freq.</span>
            </div>
            {
              variants.map((v) => (
                <div class="var-row">
                  <span class="mono">{v.hgvs}</span>
                  <span class="mono">{v.protein}</span>
                  <span class="mono var-freq">{v.freq}</span>
                </div>
              ))
            }
          </div>
          <p class="var-note">Frecuencia poblacional estimada (gnomAD v4, demo).</p>
        </article>
      </aside>
    </div>
  </section>

  <!-- ============ PANEL: DIAGNÓSTICO ============ -->
  <section class="tabpanel" id="panel-diagnostico" role="tabpanel" aria-labelledby="tab-diagnostico" hidden>
    <div class="diag-grid">
      <article class="card block">
        <h2>Criterios diagnósticos</h2>
        <ol class="steps-list">
          {
            diagnosis.criterios.map((c) => (
              <li><strong>{c.title}.</strong> {c.desc}</li>
            ))
          }
        </ol>
      </article>
      <article class="card block">
        <h2>Pruebas recomendadas</h2>
        <ul class="check-list">
          {
            diagnosis.pruebas.map((p) => (
              <li><span class="ck">✓</span> {p}</li>
            ))
          }
        </ul>
        <div class="diag-callout">
          {diagnosis.callout}
        </div>
      </article>
    </div>
  </section>

  <!-- ============ PANEL: SOURCING ============ -->
  <section class="tabpanel" id="panel-sourcing" role="tabpanel" aria-labelledby="tab-sourcing" hidden>
    <div class="sourcing-bar">
      <div class="filters" role="group" aria-label="Filtrar por categoría">
        {
          supplyCategories.map((c, i) => (
            <button class={`filter ${i === 0 ? "is-active" : ""}`} data-cat={c}>{c}</button>
          ))
        }
      </div>
      <label class="srcsearch">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4-4"/></svg>
        <input type="search" placeholder="Buscar insumo…" data-supply-search />
      </label>
    </div>

    <article class="card supply-card">
      <table class="supply-table">
        <thead>
          <tr>
            <th>Insumo</th>
            <th>Especificación técnica</th>
            <th>Laboratorio</th>
            <th>Stock</th>
            <th class="ta-right">Acción</th>
          </tr>
        </thead>
        <tbody>
          {
            supplies.map((s) => (
              <tr data-cat={s.cat} data-name={s.name.toLowerCase()}>
                <td><strong>{s.name}</strong></td>
                <td class="spec mono">{s.spec}</td>
                <td>{s.lab}</td>
                <td>
                  <span class={`chip ${stockMeta[s.stock].chip}`}>
                    <span class="dot" style={`background:currentColor`}></span>
                    {stockMeta[s.stock].text}
                  </span>
                </td>
                <td class="ta-right">
                  <button class="btn btn-ghost btn-sm">Solicitar cotización</button>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
      <p class="supply-empty" hidden>No hay insumos que coincidan con el filtro.</p>
    </article>
    <p class="sourcing-note">
      Logística de insumos vinculada a la enfermedad: encuentra dónde conseguir lo
      necesario para diagnosticarla o tratarla sin salir de la plataforma.
    </p>
  </section>

  <!-- ============ PANEL: MUESTRAS ============ -->
  <section class="tabpanel" id="panel-muestras" role="tabpanel" aria-labelledby="tab-muestras" hidden>
    <article class="card supply-card">
      <table class="supply-table">
        <thead>
          <tr>
            <th>Biobanco</th>
            <th>Ubicación</th>
            <th>Tipo de muestra</th>
            <th>Unidades</th>
            <th>Disponibilidad</th>
            <th class="ta-right">Acción</th>
          </tr>
        </thead>
        <tbody>
          {
            networkSamples.map((s) => (
              <tr>
                <td><strong>{s.biobank}</strong></td>
                <td>{s.city}</td>
                <td>{s.type}</td>
                <td class="mono">{s.n}</td>
                <td>
                  <span class={`chip ${stockMeta[s.avail].chip}`}>
                    <span class="dot" style="background:currentColor"></span>
                    {stockMeta[s.avail].text}
                  </span>
                </td>
                <td class="ta-right">
                  <a href={base + "cooperacion"} class="btn btn-ghost btn-sm">Solicitar acceso</a>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </article>
  </section>

  <!-- ============ PANEL: LITERATURA ============ -->
  <section class="tabpanel" id="panel-literatura" role="tabpanel" aria-labelledby="tab-literatura" hidden>
    <ul class="paper-list">
      {
        papers.map((p) => (
          <li class="paper card">
            <div class="paper__main">
              <span class="chip chip-teal">{p.type}</span>
              <h3>{p.title}</h3>
              <p class="paper__meta">{p.authors} · <em>{p.journal}</em> · {p.year}</p>
            </div>
            <a href="#" class="paper__link" aria-label="Abrir publicación">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</AppShell>

<style>
  /* Cabecera enfermedad */
  .disease-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
    padding: 26px 28px;
    flex-wrap: wrap;
    background: linear-gradient(135deg, #fff 60%, var(--coral-soft));
  }
  .disease-head h1 {
    font-size: 2rem;
    margin: 10px 0 14px;
  }
  .disease-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .meta-pill {
    font-size: 0.85rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 6px 13px;
    color: var(--ink-soft);
  }
  .meta-pill b {
    color: var(--muted);
    font-weight: 600;
    margin-right: 5px;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .disease-head__actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
  }

  /* Pestañas */
  .tabs {
    display: flex;
    gap: 4px;
    margin: 22px 0 20px;
    border-bottom: 1px solid var(--border);
    overflow-x: auto;
  }
  .tab {
    position: relative;
    padding: 12px 16px;
    font-size: 0.93rem;
    font-weight: 600;
    color: var(--muted);
    white-space: nowrap;
    border-bottom: 2.5px solid transparent;
    margin-bottom: -1px;
    transition: color 0.15s ease;
  }
  .tab:hover {
    color: var(--ink);
  }
  .tab.is-active {
    color: var(--coral-dark);
    border-bottom-color: var(--coral);
  }

  /* Paneles */
  .tabpanel {
    animation: fade 0.25s ease both;
  }
  .tabpanel[hidden] {
    display: none;
  }
  @keyframes fade {
    from { opacity: 0; transform: translateY(6px); }
  }

  .block {
    padding: 22px 24px;
  }
  .block + .block {
    margin-top: 18px;
  }
  .block__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }
  .block__head h2,
  .block h2 {
    font-size: 1.1rem;
  }
  .panel__sub {
    font-size: 0.8rem;
    color: var(--muted);
  }

  /* Layout asimétrico resumen */
  .resumen {
    display: grid;
    grid-template-columns: 1.65fr 1fr;
    gap: 18px;
    align-items: start;
  }

  .legend {
    display: flex;
    gap: 16px;
    font-size: 0.78rem;
    color: var(--muted);
  }
  .legend span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  /* Lista clínica */
  .clinic-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .clinic-item {
    display: flex;
    gap: 14px;
    padding: 14px 16px;
    border-radius: var(--r-md);
    background: var(--cream);
    border-left: 3px solid var(--amber-state);
  }
  .clinic-item--alta {
    border-left-color: var(--red);
    background: linear-gradient(90deg, var(--red-soft), var(--cream) 60%);
  }
  .clinic-item .chip {
    flex-shrink: 0;
    height: fit-content;
  }
  .clinic-item strong {
    font-size: 0.96rem;
  }
  .clinic-item p {
    font-size: 0.87rem;
    color: var(--ink-soft);
    margin-top: 3px;
  }

  /* Tratamientos */
  .treat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .treat {
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    padding: 14px;
    background: var(--cream);
  }
  .treat__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 7px;
  }
  .treat__top strong {
    font-size: 0.92rem;
  }
  .treat p {
    font-size: 0.83rem;
    color: var(--muted);
  }

  /* Columna genética */
  .col-gene {
    position: sticky;
    top: 84px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .block--dark {
    background: var(--ink);
    color: #efe4da;
  }
  .gene-title {
    color: #fff;
    margin-bottom: 16px;
  }
  .gene-facts {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .gene-facts > div {
    display: flex;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.09);
  }
  .gene-facts > div:last-child {
    border-bottom: none;
  }
  .gene-facts dt {
    color: #ab9f96;
    font-size: 0.86rem;
  }
  .gene-facts dd {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--amber-soft);
    font-weight: 500;
  }

  /* Tabla de variantes */
  .var-table {
    display: flex;
    flex-direction: column;
  }
  .var-row {
    display: grid;
    grid-template-columns: 1fr 1fr 0.6fr;
    gap: 8px;
    padding: 10px 6px;
    border-bottom: 1px solid var(--border);
    align-items: center;
  }
  .var-row--head {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    font-weight: 600;
  }
  .var-row--head span {
    font-family: var(--font-sans);
  }
  .mono {
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }
  .var-freq {
    text-align: right;
    color: var(--coral-dark);
    font-weight: 500;
  }
  .var-note {
    font-size: 0.76rem;
    color: var(--muted);
    margin-top: 12px;
  }

  /* Diagnóstico */
  .diag-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  .steps-list {
    padding-left: 18px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .steps-list li {
    font-size: 0.9rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }
  .check-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 18px;
  }
  .check-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
  }
  .ck {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--green-soft);
    color: var(--green);
    display: grid;
    place-items: center;
    font-size: 0.78rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .diag-callout {
    background: var(--amber-soft);
    border-radius: var(--r-md);
    padding: 14px 16px;
    font-size: 0.88rem;
    color: var(--amber-deep);
  }

  /* Sourcing */
  .sourcing-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .filters {
    display: flex;
    gap: 7px;
    flex-wrap: wrap;
  }
  .filter {
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--ink-soft);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 7px 14px;
    transition: all 0.15s ease;
  }
  .filter:hover {
    border-color: var(--coral);
  }
  .filter.is-active {
    background: var(--coral);
    color: #fff;
    border-color: var(--coral);
  }
  .srcsearch {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 8px 14px;
    color: var(--muted);
    min-width: 220px;
  }
  .srcsearch:focus-within {
    border-color: var(--coral);
  }
  .srcsearch input {
    border: none;
    outline: none;
    background: none;
    font-family: inherit;
    font-size: 0.88rem;
    color: var(--ink);
    width: 100%;
  }

  /* Tablas */
  .supply-card {
    padding: 6px 6px 6px;
    overflow-x: auto;
  }
  .supply-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 720px;
  }
  .supply-table th {
    text-align: left;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    font-weight: 600;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
  }
  .supply-table td {
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
    vertical-align: middle;
  }
  .supply-table tbody tr:last-child td {
    border-bottom: none;
  }
  .supply-table tbody tr {
    transition: background 0.12s ease;
  }
  .supply-table tbody tr:hover {
    background: var(--cream);
  }
  .spec {
    color: var(--ink-soft);
    font-size: 0.8rem !important;
  }
  .ta-right {
    text-align: right;
  }
  .supply-empty {
    padding: 28px;
    text-align: center;
    color: var(--muted);
  }
  .sourcing-note {
    margin-top: 14px;
    font-size: 0.84rem;
    color: var(--muted);
    max-width: 640px;
  }

  /* Literatura */
  .paper-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .paper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 22px;
  }
  .paper__main h3 {
    font-size: 1.02rem;
    margin: 9px 0 5px;
  }
  .paper__meta {
    font-size: 0.85rem;
    color: var(--muted);
  }
  .paper__link {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: var(--cream);
    display: grid;
    place-items: center;
    color: var(--coral-dark);
    flex-shrink: 0;
  }
  .paper__link:hover {
    background: var(--coral-soft);
  }

  /* Responsive */
  @media (max-width: 920px) {
    .resumen,
    .diag-grid,
    .treat-grid {
      grid-template-columns: 1fr;
    }
    .col-gene {
      position: static;
    }
  }

  /* Impresión (Exportar PDF) */
  @media print {
    .tab,
    .disease-head__actions button,
    .sourcing-bar {
      display: none !important;
    }
    .tabpanel[hidden] {
      display: block !important;
    }
  }
</style>

<script>
  // --- Navegación por pestañas ---
  const tabButtons = Array.from(document.querySelectorAll<HTMLButtonElement>(".tab"));
  const panels = Array.from(document.querySelectorAll<HTMLElement>(".tabpanel"));

  function activate(id: string) {
    tabButtons.forEach((b) => {
      const on = b.dataset.tab === id;
      b.classList.toggle("is-active", on);
      b.setAttribute("aria-selected", on ? "true" : "false");
    });
    panels.forEach((p) => {
      const on = p.id === `panel-${id}`;
      p.hidden = !on;
      p.classList.toggle("is-active", on);
    });
  }
  tabButtons.forEach((b) =>
    b.addEventListener("click", () => activate(b.dataset.tab!))
  );

  // --- Filtros de sourcing (categoría + búsqueda) ---
  const filters = Array.from(document.querySelectorAll<HTMLButtonElement>(".filter"));
  const rows = Array.from(document.querySelectorAll<HTMLTableRowElement>("[data-cat][data-name]"));
  const searchInput = document.querySelector<HTMLInputElement>("[data-supply-search]");
  const emptyMsg = document.querySelector<HTMLElement>(".supply-empty");
  let activeCat = "Todos";

  function applyFilter() {
    const q = (searchInput?.value ?? "").trim().toLowerCase();
    let shown = 0;
    rows.forEach((r) => {
      const catOk = activeCat === "Todos" || r.dataset.cat === activeCat;
      const qOk = !q || (r.dataset.name ?? "").includes(q);
      const visible = catOk && qOk;
      r.style.display = visible ? "" : "none";
      if (visible) shown++;
    });
    if (emptyMsg) emptyMsg.hidden = shown !== 0;
  }
  filters.forEach((f) =>
    f.addEventListener("click", () => {
      filters.forEach((x) => x.classList.remove("is-active"));
      f.classList.add("is-active");
      activeCat = f.dataset.cat!;
      applyFilter();
    })
  );
  searchInput?.addEventListener("input", applyFilter);
</script>
