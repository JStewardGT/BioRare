---
import Logo from "./Logo.astro";
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<header class="nav">
  <div class="container nav__inner">
    <Logo />
    <nav class="nav__links" aria-label="Navegación principal">
      <a href="#plataforma">Plataforma</a>
      <a href="#biobancos">Biobancos</a>
      <a href="#cooperacion">Cooperación</a>
    </nav>
    <a href={base + "dashboard"} class="btn btn-primary btn-sm nav__cta">
      Ver plataforma
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(253, 247, 242, 0.82);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    gap: 24px;
  }
  .nav__links {
    display: flex;
    gap: 30px;
    margin-left: auto;
    margin-right: 12px;
  }
  .nav__links a {
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--ink-soft);
    transition: color 0.15s ease;
  }
  .nav__links a:hover {
    color: var(--coral-dark);
  }
  @media (max-width: 720px) {
    .nav__links {
      display: none;
    }
  }
</style>
