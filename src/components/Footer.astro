---
import Logo from "./Logo.astro";
const year = 2026;
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <Logo />
      <p>
        Estandarización e interoperabilidad de datos clínicos y biobancos para
        acelerar la investigación en enfermedades raras.
      </p>
    </div>
    <div class="footer__cols">
      <div>
        <h4>Plataforma</h4>
        <a href="#plataforma">Buscador científico</a>
        <a href="#biobancos">Biobancos</a>
        <a href="#cooperacion">Cooperación</a>
        <a href="#">Documentación</a>
      </div>
      <div>
        <h4>Instituciones</h4>
        <a href="#">Hospitales</a>
        <a href="#">Laboratorios</a>
        <a href="#">Universidades</a>
      </div>
      <div>
        <h4>Recursos</h4>
        <a href="#">Estándares (ORPHA / ICD-10)</a>
        <a href="#">Política de datos</a>
        <a href="#">Contacto</a>
      </div>
    </div>
  </div>
  <div class="container footer__legal">
    <span>© {year} BioRare · Proyecto académico</span>
    <span>Construido con Astro · Datos de demostración</span>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink);
    color: #d9cfc6;
    padding: 64px 0 28px;
    margin-top: 80px;
  }
  .footer__inner {
    display: grid;
    grid-template-columns: 1.4fr 2fr;
    gap: 48px;
  }
  .footer__brand p {
    margin-top: 16px;
    max-width: 320px;
    font-size: 0.92rem;
    color: #ab9f96;
    line-height: 1.6;
  }
  .footer__brand :global(.logo) {
    color: #fff;
  }
  .footer__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .footer__cols h4 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--amber-soft);
    margin-bottom: 14px;
  }
  .footer__cols a {
    display: block;
    font-size: 0.9rem;
    color: #c3b8af;
    padding: 5px 0;
    transition: color 0.15s ease;
  }
  .footer__cols a:hover {
    color: #fff;
  }
  .footer__legal {
    display: flex;
    justify-content: space-between;
    margin-top: 48px;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.82rem;
    color: #8b7f76;
  }
  @media (max-width: 820px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .footer__legal {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
