---
interface Props {
  light?: boolean; // texto claro para fondos oscuros
}
const { light = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<a href={base} class={`logo ${light ? "logo--light" : ""}`} aria-label="BioRare, inicio">
  <span class="logo__mark" aria-hidden="true">
    <svg viewBox="0 0 32 32" width="32" height="32">
      <rect width="32" height="32" rx="9" fill="var(--coral)"></rect>
      <path
        d="M11 9v14M11 9c5 0 5 6 0 6 5 0 5 8 0 8M21 9v14M21 23c-5 0-5-6 0-6-5 0-5-8 0-8"
        stroke="white"
        stroke-width="2"
        stroke-linecap="round"
        fill="none"></path>
    </svg>
  </span>
  <span class="logo__text">Bio<span class="logo__accent">Rare</span></span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    font-size: 1.22rem;
    letter-spacing: -0.03em;
    color: var(--ink);
  }
  .logo__mark {
    display: grid;
    place-items: center;
    filter: drop-shadow(0 4px 10px rgba(232, 93, 78, 0.3));
  }
  .logo__accent {
    color: var(--coral);
  }
  .logo--light {
    color: #fff;
  }
  .logo--light .logo__accent {
    color: var(--amber-soft);
  }
</style>
