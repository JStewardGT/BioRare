---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "BioRare · Estandarización global de datos en enfermedades raras",
  description = "Plataforma de estandarización e interoperabilidad de datos y biobancos para la investigación en enfermedades raras.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%23e85d4e'/%3E%3Cpath d='M11 9v14M11 9c5 0 5 6 0 6 5 0 5 8 0 8M21 9v14M21 23c-5 0-5-6 0-6-5 0-5-8 0-8' stroke='white' stroke-width='2' stroke-linecap='round' fill='none'/%3E%3C/svg%3E"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
